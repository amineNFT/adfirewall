# Ritual Chain RPC (public testnet)
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Deployed AdFirewall contract address (from `forge script Deploy`)
NEXT_PUBLIC_AD_FIREWALL_ADDRESS=0x0000000000000000000000000000000000000000

# Server-side relayer key used by /api/moderate to submit moderation txns.
# (Browser wallets can't sign async-precompile calls.) This key must hold a
# RitualWallet deposit for LLM fees. SERVER-ONLY — never prefixed NEXT_PUBLIC_.
PRIVATE_KEY=0xyour_funded_private_key
